# === Production Environment Variables ===
# Copy to .env.production and fill in values

# --- Database ---
POSTGRES_USER=incentivedrive
POSTGRES_PASSWORD=          # Generate: openssl rand -hex 32
DATABASE_URL=               # Set by docker-compose or cloud provider

# --- Redis ---
REDIS_PASSWORD=             # Generate: openssl rand -hex 32

# --- API Secrets ---
API_SECRET_KEY=             # Generate: openssl rand -hex 32
JWT_SECRET_KEY=             # Generate: openssl rand -hex 32

# --- SendGrid (required for ADF lead delivery) ---
SENDGRID_API_KEY=           # https://app.sendgrid.com/settings/api_keys

# --- Optional: External APIs ---
MARKETCHECK_API_KEY=        # https://www.marketcheck.com/apis/
TRUSTEDFORM_API_KEY=        # https://activeprospect.com/trustedform/
STRIPE_SECRET_KEY=          # https://dashboard.stripe.com/apikeys
STRIPE_WEBHOOK_SECRET=

# --- App URLs (set to your domain) ---
NEXT_PUBLIC_API_BASE_URL=https://api.incentivedrive.com/api/v1
NEXT_PUBLIC_WEB_URL=https://incentivedrive.com

# --- Ports (for docker-compose) ---
API_PORT=8000
WEB_PORT=3000
